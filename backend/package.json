{
  "name": "todolist-backend",
  "version": "1.0.0",
  "description": "Multi-Tenant Backend API for ToDoList",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "prisma:main:generate": "prisma generate --schema=prisma-main/schema.prisma",
    "prisma:main:migrate": "prisma migrate dev --schema=prisma-main/schema.prisma --name init",
    "prisma:main:deploy": "prisma migrate deploy --schema=prisma-main/schema.prisma",
    "prisma:main:studio": "prisma studio --schema=prisma-main/schema.prisma",
    "prisma:tenant:generate": "prisma generate --schema=prisma-tenant/schema.prisma",
    "prisma:tenant:migrate": "prisma migrate dev --schema=prisma-tenant/schema.prisma --name init",
    "prisma:tenant:deploy": "prisma migrate deploy --schema=prisma-tenant/schema.prisma",
    "prisma:tenant:studio": "prisma studio --schema=prisma-tenant/schema.prisma",
    "seed:main": "node prisma-main/seed.js",
    "setup": "npm run prisma:main:generate && npm run prisma:tenant:generate && npm run prisma:main:migrate && npm run seed:main"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.22.0",
    "socket.io": "^4.7.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.0.0"
  },
  "keywords": [
    "nodejs",
    "express",
    "prisma",
    "postgresql",
    "multi-tenant"
  ],
  "author": "",
  "license": "ISC"
}
